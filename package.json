{
  "name": "workspacer",
  "version": "1.0.0",
  "description": "A horizontal-scroll workspace for agent-driven development",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "cd src/renderer && npx vite --port 5173",
    "dev:main": "npm run build:main && wait-on http://localhost:5173 && cross-env ELECTRON_DEV=1 electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "cd src/renderer && npx vite build",
    "build": "npm run build:main && npm run build:renderer",
    "package": "npm run build && electron-builder",
    "rebuild": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "wait-on": "^9.0.4"
  }
}
