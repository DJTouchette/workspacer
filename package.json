{
  "name": "workspacer",
  "version": "1.0.0",
  "description": "A horizontal-scroll workspace for agent-driven development",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "cd src/renderer && npx vite --port 5173",
    "dev:main": "npm run build:main && wait-on http://localhost:5173 && cross-env ELECTRON_DEV=1 electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "cd src/renderer && npx vite build",
    "build": "npm run build:main && npm run build:renderer",
    "package": "npm run build && electron-builder",
    "rebuild": "electron-builder install-app-deps",
    "test": "npm run test:main && npm run test:renderer",
    "test:main": "vitest run",
    "test:renderer": "cd src/renderer && npx vitest run",
    "test:e2e": "npm run build && npx playwright test",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "better-sqlite3": "^11.0.0",
    "js-yaml": "^4.1.0"
  },
  "build": {
    "appId": "com.workspacer.app",
    "productName": "Workspacer",
    "asar": true,
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "!node_modules/**/*.{md,map,ts}",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/__tests__/**",
      "!node_modules/**/docs/**",
      "!node_modules/**/.github/**",
      "!**/*.d.ts"
    ],
    "asarUnpack": [
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/**",
      "node_modules/better-sqlite3/**"
    ],
    "electronLanguages": ["en-US"],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.1",
    "wait-on": "^9.0.4"
  }
}
