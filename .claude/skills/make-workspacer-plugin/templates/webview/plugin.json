{
  "id": "owner.my-webview",
  "name": "My Webview",
  "apiVersion": "1",
  "ui": "ui",
  "panes": [
    {
      "type": "owner.my-webview",
      "title": "My Webview",
      "icon": "🪟",
      "scope": "global"
    }
  ],
  "hotkeys": [
    {
      "id": "open-my-webview",
      "default": "ctrl+shift+u",
      "command": "open-pane:owner.my-webview"
    }
  ],
  "settings": [
    {
      "key": "compact",
      "label": "Compact layout",
      "type": "boolean",
      "default": false,
      "help": "Delivered live via window.__WKS_SETTINGS__ + a settings bus event (no restart)."
    }
  ],
  "capabilities": [
    "agents.list"
  ],
  "emits": [],
  "consumes": [
    "agent.state_changed",
    "agent.snapshot"
  ]
}
