{
  "name": "workspacer",
  "version": "1.0.1",
  "description": "A horizontal-scroll workspace for agent-driven development",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:share": "cross-env WORKSPACER_REMOTE_SHARE=1 npm run dev",
    "dev:renderer": "cd src/renderer && npx vite --port 5173",
    "dev:main": "npm run build:hub && npm run build:main && wait-on http://localhost:5173 && cross-env ELECTRON_DEV=1 electron .",
    "build:main": "tsc -p tsconfig.main.json && npm run bundle:preload",
    "bundle:preload": "esbuild src/main/preload.ts --bundle --platform=node --format=cjs --external:electron --target=node18 --outfile=dist/main/preload.js",
    "build:hub": "cd ../../services/hub && go build -o . ./cmd/hub",
    "build:mcp": "cd ../../services/hub && go build -o . ./cmd/mcp",
    "build:claudemon": "cd ../../services/claudemon && cargo build --release",
    "test:hub": "cd ../../services/hub && go test -race ./...",
    "build:renderer": "cd src/renderer && npx vite build",
    "build:renderer:web": "cd src/renderer && npx vite build --config vite.config.web.ts",
    "dev:web": "npm run build:renderer:web && npm run dev:share",
    "build": "npm run build:main && npm run build:renderer",
    "package": "npm run build && npm run build:hub && npm run build:claudemon && electron-builder",
    "postinstall": "npx electron-rebuild -f -w better-sqlite3",
    "rebuild": "electron-builder install-app-deps",
    "test": "npm run test:main && npm run test:renderer",
    "test:main": "vitest run",
    "test:renderer": "cd src/renderer && npx vitest run",
    "test:e2e": "npm run build && npx playwright test",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "js-yaml": "^4.1.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.0.0",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.0",
    "vitest": "^4.1.1",
    "wait-on": "^9.0.4"
  }
}
