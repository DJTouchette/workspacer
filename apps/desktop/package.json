{
  "name": "workspacer",
  "version": "0.126.2",
  "description": "A control plane and IDE for coding agents",
  "homepage": "https://github.com/DJTouchette/workspacer",
  "author": "Damien Touchette <damien.touchette@businessinfusions.com>",
  "license": "BUSL-1.1",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:share": "cross-env WORKSPACER_REMOTE_SHARE=1 npm run dev",
    "dev:renderer": "cd src/renderer && npx vite --port 5173",
    "dev:main": "npm run build:hub && npm run build:mcp && npm run build:cli && npm run build:claudemon && npm run build:main && npm run ensure:web && wait-on http://localhost:5173 && cross-env ELECTRON_DEV=1 electron .",
    "build:main": "tsc -p tsconfig.main.json && npm run bundle:preload",
    "gen:config-defaults": "node scripts/gen-config-defaults.mjs",
    "prebuild:main": "node scripts/gen-config-defaults.mjs",
    "bundle:preload": "esbuild src/main/preload.ts --bundle --platform=node --format=cjs --external:electron --target=node18 --outfile=dist/main/preload.js",
    "build:hub": "cd ../../services/hub && go build -o . ./cmd/hub && go build -o . ./cmd/brain",
    "build:mcp": "cd ../../services/hub && go build -o . ./cmd/mcp",
    "build:cli": "cd ../../services/hub && go build -o . ./cmd/workspacer",
    "build:claudemon": "cd ../../services/claudemon && cargo build --release",
    "test:hub": "cd ../../services/hub && go test -race ./...",
    "build:renderer": "cd src/renderer && npx vite build",
    "build:renderer:web": "cd src/renderer && npx vite build --config vite.config.web.ts",
    "ensure:web": "node -e \"process.exit(require('fs').existsSync('dist/web/index.html')?0:1)\" || npm run build:renderer:web",
    "dev:web": "npm run build:renderer:web && npm run dev:share",
    "build": "npm run build:main && npm run build:renderer && npm run build:renderer:web",
    "package": "npm run build && npm run build:hub && npm run build:mcp && npm run build:cli && npm run build:claudemon && electron-builder",
    "postinstall": "npx electron-rebuild -f -w better-sqlite3",
    "rebuild": "electron-builder install-app-deps",
    "typecheck": "npm run typecheck:main && npm run typecheck:renderer",
    "typecheck:main": "tsc -p tsconfig.main.json --noEmit",
    "typecheck:renderer": "cd src/renderer && tsc -p tsconfig.json --noEmit",
    "test": "npm run test:main && npm run test:renderer",
    "test:main": "vitest run",
    "test:renderer": "cd src/renderer && npx vitest run",
    "test:e2e": "npm run build && npx playwright test",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"*.ts\""
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.18.0",
    "better-sqlite3": "^11.0.0",
    "electron-updater": "^6.8.9",
    "js-yaml": "^4.1.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.0.0",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.21.5",
    "prettier": "3.9.4",
    "typescript": "^5.6.0",
    "vitest": "^4.1.1",
    "wait-on": "^9.0.4"
  }
}
