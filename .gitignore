# Dependencies & build output (match at any depth across the monorepo)
node_modules/
dist/
release/
*.js.map
.DS_Store

# Rust target dirs (apps/tui, services/claudemon)
target/

# hub build artifacts (built by `npm run build:hub` / `npm run build:mcp`)
services/hub/hub
services/hub/hub.exe
services/hub/hub.exe~
services/hub/mcp
services/hub/mcp.exe
services/hub/brain
services/hub/brain.exe

# Committed binaries don't belong in source control (deleted from history going forward)
/bin/
/workspacer

# A global ignore (~/.gitignore_global) has a `claude/` rule (meant for `.claude/`)
# that wrongly matches this source directory, so new files in it were silently
# untracked. Re-include the directory and its contents for this repo.
!apps/desktop/src/renderer/src/components/claude/
!apps/desktop/src/renderer/src/components/claude/**
