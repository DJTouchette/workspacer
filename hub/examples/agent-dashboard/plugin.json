{
  "id": "workspacer.agent-dashboard",
  "name": "Agent Dashboard",
  "apiVersion": "1",
  "server": {
    "command": "python3",
    "args": ["-m", "http.server", "9112", "--bind", "127.0.0.1"],
    "port": 9112,
    "health": "/"
  },
  "panes": [
    { "type": "workspacer.agent-dashboard", "title": "Agents", "icon": "📊", "path": "/index.html", "scope": "global" }
  ],
  "hotkeys": [
    { "id": "open-dashboard", "default": "ctrl+shift+a", "command": "open-pane:workspacer.agent-dashboard" }
  ],
  "consumes": ["agent.state_changed", "agent.snapshot"],
  "capabilities": ["agents.list", "agents.sendMessage", "notifications.post"]
}
